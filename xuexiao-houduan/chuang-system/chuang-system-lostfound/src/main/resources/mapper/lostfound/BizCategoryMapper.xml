<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="cn.zhangchuangla.system.lostfound.mapper.BizCategoryMapper">

    <!-- 统计分类下的帖子数量 -->
    <select id="countPostsByCategoryId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM biz_post
        WHERE category_id = #{categoryId}
          AND is_deleted = '0'
    </select>

</mapper>
